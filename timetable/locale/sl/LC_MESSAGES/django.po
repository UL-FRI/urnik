#, python-format
msgid ""
"This action will notify <span class=\"teacher-name\">%(teacher)s</span> that "
"you've declined their offer."
msgstr ""
"To dejanje bo obvestilo <span class=\"teacher-name\">%(teacher)s</span>, da "
"ste zavrnili njihovo ponudbo."

