msgid "View your current timetable"
msgstr "Oglejte si svoj trenutni urnik"

msgid "Check room availability"
msgstr "Preverite razpoložljivost prostorov"

msgid "Access your preferences"
msgstr "Dostopajte do svojih nastavitev"

msgid "Contact your colleagues directly"
msgstr "Obrnite se neposredno na kolege"

msgid "If you have questions about when trading will be re-enabled, please contact your timetable administrator."
msgstr "Če imate vprašanja o tem, kdaj bo menjava ponovno omogočena, se obrnite na skrbnika urnika."

msgid "Back to Timetable"
msgstr "Nazaj na urnik"
