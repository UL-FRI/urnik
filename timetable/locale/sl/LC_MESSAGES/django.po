#, python-format
msgid "This message will be visible to %(teacher)s."
msgstr "To sporočilo bo vidno %(teacher)s."

# Trading disabled page
msgid "Trading Disabled"
msgstr "Menjava onemogočena"

msgid "Trade requests are currently not available for this timetable"
msgstr "Zahteve za menjavo trenutno niso na voljo za ta urnik"

